# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Database provider:
# - sqlite (default): uses local database.sqlite file
# - mysql: connects to MySQL (e.g. XAMPP)
DB_PROVIDER="sqlite"

# MySQL (XAMPP) settings (only used when DB_PROVIDER="mysql")
# Create the database first (e.g. "cycle_track_ai") in phpMyAdmin.
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="cycletrackai"
MYSQL_PASSWORD=""
MYSQL_DATABASE="cycle_track_ai"

# Admin / Developer portal
# - First admin can always sign up.
# - After that, signups are blocked unless:
#   - ADMIN_SIGNUP_OPEN="true" OR
#   - a valid ADMIN_INVITE_CODE is provided during signup.
ADMIN_INVITE_CODE=""
ADMIN_SIGNUP_OPEN="false"
ADMIN_SESSION_TTL_DAYS="7"
